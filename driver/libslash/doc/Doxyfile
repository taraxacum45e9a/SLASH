# Doxyfile for libslash — generates XML for Sphinx/Breathe integration.

PROJECT_NAME           = "libslash"
PROJECT_BRIEF          = "Userspace C library for the SLASH kernel driver"

OUTPUT_DIRECTORY       = ./docs

INPUT                  = ../include
RECURSIVE              = YES
FILE_PATTERNS          = *.h

EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
OPTIMIZE_OUTPUT_FOR_C  = YES

MACRO_EXPANSION        = YES
PREDEFINED             = __inline__=inline \
                         __attribute__(x)=

GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
