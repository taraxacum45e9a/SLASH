# Ignore build directories
**/build/
/cmake-build-debug/
/cmake-build-release/
**/build_*
# Ignore CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
#Makefile

# Ignore compiled dynamic libraries
*.dll
*.so
*.dylib

# Ignore compiled static libraries
*.lib
*.a

# Ignore object files
*.o
*.obj

# Ignore executable files
*.exe
*.out
*.app

# Ignore logs and databases
*.jou
*.log
*.sql
*.sqlite

# Ignore system files
.DS_Store
Thumbs.db

# Ignore IDE specific files
.vscode/
.idea/
*.iml

# Ignore test binaries
/tests/*.exe
/tests/*.out
/tests/*.o
/tests/*.obj

# Ignore user-specific files
*.swp
*~
*.Xil
!build_all.sh
!build_bsp.sh

.clang-format
.cache
**/linker_results/
**/linker_results_*/

__pycache__/
*.pyc
.venv/

# Kernel module kcompat probe scratch (driver/kcompat/probe.sh)
driver/kcompat/.scratch/

# Build files for package
/pbuild/
/rpmbuild/
/debian/

# Output files for package
/deb/
/rpm/
/docker-build/

# VBIN build directories
*.prj

# Python virtual environment
.venv

# Python test coverage
.coverage
